public-hoist-pattern[]=*
auto-install-peers=true
side-effects-cache=true
# Industrial-Grade build script authorization (array sintaksa — obavezno za pnpm)
only-built-dependencies[]=@parcel/watcher
only-built-dependencies[]=esbuild
only-built-dependencies[]=protobufjs
only-built-dependencies[]=sharp
only-built-dependencies[]=workerd
only-built-dependencies[]=@swc/core
# Osigurava da se Linux x64 binarni fajlovi (workerd) preuzmu i na macOS lockfile-u
supportedArchitectures[]=linux
supportedArchitectures[]=x64
supportedArchitectures[]=current
