public-hoist-pattern[]=*
auto-install-peers=true
side-effects-cache=true
# Industrial-Grade build script authorization
only-built-dependencies=@parcel/watcher,esbuild,protobufjs,sharp,workerd,@swc/core
# Osigurava da se Linux x64 binarni fajlovi (workerd) preuzmu i na macOS lockfile-u
supportedArchitectures[]=linux
supportedArchitectures[]=x64
supportedArchitectures[]=current
