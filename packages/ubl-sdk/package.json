{
  "name": "@dlbr/ubl-sdk",
  "version": "1.0.8",
  "type": "module",
  "description": "Ultra-brzi, Edge-native JSON-to-UBL 2.1 XML generator prilagođen specifikacijama srpskog SEF-a",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dlbr/ubl-sdk.git"
  },
  "homepage": "https://github.com/dlbr/ubl-sdk#readme",
  "bugs": {
    "url": "https://github.com/dlbr/ubl-sdk/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "test": "vitest run"
  },
  "license": "MIT",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sef",
    "ubl",
    "e-fakture",
    "srbija",
    "cloudflare-workers",
    "xml"
  ],
  "devDependencies": {
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0",
    "vitest": "^1.4.0"
  },
  "dependencies": {
    "valibot": "^1.4.0"
  }
}