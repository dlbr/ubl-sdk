{
  "name": "sef-bridge-monorepo",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:backend": "pnpm --filter @sef/backend dev",
    "dev:frontend": "pnpm --filter @sef/frontend dev",
    "build": "pnpm -r build",
    "deploy": "pnpm -r deploy",
    "build:frontend": "pnpm --filter @sef/frontend build",
    "deploy:backend": "pnpm --filter @sef/backend deploy",
    "deploy:frontend": "pnpm --filter @sef/frontend",
    "test": "vitest run",
    "test:clean": "pnpm test && killall esbuild 2>/dev/null || true",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release:sync": "bash scripts/sync-ubl-sdk.sh"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@cloudflare/vitest-pool-workers": "^0.16.9",
    "@cloudflare/workers-types": "^4.20260523.1",
    "pdf-parse": "^2.4.5",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  }
}