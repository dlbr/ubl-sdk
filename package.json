{
  "name": "@dlbr/sef-ubl-builder",
  "version": "1.0.0",
  "type": "module",
  "description": "Ultra-brzi, Edge-native JSON-to-UBL 2.1 XML generator prilagođen specifikacijama srpskog SEF-a",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc && esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js",
    "deploy": "pnpm build && wrangler deploy"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "sef",
    "ubl",
    "e-fakture",
    "srbija",
    "cloudflare-workers",
    "xml"
  ],
  "devDependencies": {
    "esbuild": "^0.25.0",
    "vitest": "^1.4.0",
    "typescript": "^5.4.0"
  }
}
